      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0ad32sr0dxy0wy13120sg0xdmw02]&quot;' value='Change in %' />
        </aliases>
      </column>
      <column aggregation='Sum' caption='Study Period' datatype='integer' name='[Calculation_6930758386264137728]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='If [Date]&gt;=[Parameters].[Parameter 1] And [Date]&lt;=[Parameters].[Parameter 2] Then 1&#10;Else 0&#10;END' />
      </column>
      <column caption='Switch' datatype='string' name='[Calculation_6930758386264825857]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 3]' />
      </column>
      <column caption='Change price from low to high' datatype='real' name='[Calculation_6930758386267672578]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Low])-SUM([High])' />
      </column>
      <column caption='Change price from close to open' datatype='real' name='[Calculation_6930758386267901955]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Close])-SUM([Open])' />
      </column>
      <column caption='increase?' datatype='boolean' name='[Calculation_6930758386268119044]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_6930758386267901955]&gt;0' />
      </column>
      <column caption='Company Name' datatype='string' name='[Calculation_6930758386276937736]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Table Name]&#10;WHEN &quot;TSLA.csv&quot; THEN &quot;Tesla&quot;&#10;WHEN &quot;AAPL.csv&quot; THEN &quot;Apple&quot;&#10;WHEN &quot;MSFT.csv&quot; THEN &quot;Microsoft&quot;&#10;WHEN &quot;JPM.csv&quot; THEN &quot;JPMorgan Chase &amp; Co&quot;&#10;ELSE &quot;Unknown Company&quot;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Last Day Only' datatype='integer' name='[Calculation_6930758386278236169]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [Date]= {FIXED: MAX([Parameters].[Parameter 2])} THEN 1&#10;ELSE 0&#10;END' />
      </column>
      <column caption='Upper Price' datatype='string' name='[Calculation_6930758386283859978]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='If [Percent change in price]&gt; 0 THEN &apos;▲&apos;&#10;END' />
      </column>
      <column caption='Down Price' datatype='string' name='[Calculation_6930758386284359691]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Percent change in price] &lt; 0 THEN &apos;▼&apos;&#10;END' />
      </column>
      <column caption='Last day text' datatype='string' name='[Calculation_6930758386306596879]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Last day:&quot;' />
      </column>
      <column caption='Last day' datatype='date' name='[Calculation_6930758386306781200]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='MAX([Parameters].[Parameter 2])' />
      </column>
      <column caption='change in price&gt;0?' datatype='boolean' name='[Calculation_6930758386334199828]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Change in price]&gt;0' />
      </column>
      <column caption='Day over Day Price Change' datatype='real' name='[Calculation_6930758386359586840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Close]) - LOOKUP(SUM([Close]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Plot d over d' datatype='boolean' name='[Calculation_6930758386359738393]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_6930758386359586840] &gt; 0'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Previous day open price' datatype='real' name='[Calculation_6930758386374533150]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOOKUP(SUM([Open]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Start Close Price' datatype='real' name='[Calculation_6930758389208715306]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Date] = [Parameters].[Parameter 1] THEN [Close]&#10;END' />
      </column>
      <column caption='Return %' datatype='real' name='[Calculation_6930758389208899627]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_6930758389215473709]-[Start Date Close Price (copy)_6930758389215707182])/[Start Date Close Price (copy)_6930758389215707182]' />
      </column>
      <column caption='End Close Price' datatype='real' name='[Calculation_6930758389209116716]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Date] = [Parameters].[Parameter 2] THEN [Close]&#10;END' />
      </column>
      <column caption='End Date Close Price' datatype='real' name='[Calculation_6930758389215473709]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN([Calculation_6930758389209116716])' />
      </column>
      <column caption='Change price btw start end date' datatype='real' name='[Calculation_6930758389220081712]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_6930758389215473709]-[Start Date Close Price (copy)_6930758389215707182]' />
      </column>
      <column caption='Index' datatype='real' name='[Calculation_6930758389220737073]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([Calculation_6930758389220081712]) THEN&#10;    NULL&#10;ELSE&#10;    [Calculation_6930758389220081712] + 100&#10;END' />
      </column>
      <column caption='Volume Osc Interpretation' datatype='string' name='[Calculation_6930758389232058419]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Volume_Osc] &gt; 0 THEN&#10;&quot;Short-term volume exceeds the long-term average,&#10;indicating stronger market participation.&quot;&#10;&#10;ELSEIF [Volume_Osc] &lt; 0 THEN&#10;&quot;Short-term volume is below the long-term average,&#10;indicating weaker market participation.&quot;&#10;&#10;ELSE&#10;&quot;Market activity is stable&quot;&#10;END' />
      </column>
      <column datatype='real' name='[Close]' role='measure' type='quantitative' />
      <column caption='Down Volume' datatype='string' name='[Down Price (copy)_6930758386287333389]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Percent change in volume] &lt; 0 THEN &apos;▼&apos;&#10;END' />
      </column>
      <column datatype='real' name='[MA20]' role='measure' type='quantitative' />
      <column datatype='real' name='[MA50]' role='measure' type='quantitative' />
      <column datatype='real' name='[MA5]' role='measure' type='quantitative' />
      <column caption='Start Date Close Price' datatype='real' name='[Start Date Close Price (copy)_6930758389215707182]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN([Calculation_6930758389208715306])' />
